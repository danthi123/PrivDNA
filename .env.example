# PrivDNA Website
# Generate with: openssl rand -hex 32
DATABASE_KEY=

# Base path for all persistent data (bind mounts)
# All container volumes are stored under this directory
DATA_DIR=

# Rybbit Analytics
# Get from Rybbit dashboard after first setup
RYBBIT_SITE_ID=
# Generate with: openssl rand -hex 16
RYBBIT_DB_PASSWORD=
# Generate with: openssl rand -hex 32
RYBBIT_AUTH_SECRET=

# Cloudflare Tunnel
# Get from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=
