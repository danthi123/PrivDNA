# PrivDNA Website
# Generate with: openssl rand -hex 32
DATABASE_KEY=

# Base path for all persistent data (bind mounts)
# All container volumes are stored under this directory
DATA_DIR=

# Rybbit Analytics
# Get from Rybbit dashboard after first setup
RYBBIT_SITE_ID=
# Rybbit public URL (used for tracking script src and dashboard)
RYBBIT_URL=
# Generate with: openssl rand -hex 16
RYBBIT_DB_PASSWORD=
# Generate with: openssl rand -hex 16
RYBBIT_CLICKHOUSE_PASSWORD=
# Generate with: openssl rand -hex 32
RYBBIT_AUTH_SECRET=

# Cloudflare Tunnel
# Get from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# SMTP configuration (Proton Mail Bridge or similar)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# HMAC secret for unsubscribe tokens (generate with: openssl rand -hex 32)
UNSUBSCRIBE_SECRET=

# Base URL for email links (your primary domain)
BASE_URL=
