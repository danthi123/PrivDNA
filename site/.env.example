# Database encryption key (generate with: openssl rand -hex 32)
DATABASE_KEY=

# Email encryption key — MUST be different from DATABASE_KEY
# Used for AES-256-GCM encryption and HMAC-SHA256 hashing
# Generate with: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=

# Rybbit analytics site ID (from your Rybbit instance)
RYBBIT_SITE_ID=

# Rybbit instance URL (self-hosted)
RYBBIT_URL=

# SMTP configuration (Proton Mail Bridge or similar)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# Base URL for email links
BASE_URL=
