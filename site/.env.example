# Database encryption key (generate with: openssl rand -hex 32)
DATABASE_KEY=

# Rybbit analytics site ID (from your Rybbit instance)
RYBBIT_SITE_ID=

# Rybbit instance URL (self-hosted)
RYBBIT_URL=http://rybbit-server:3002

# SMTP configuration (Proton Mail Bridge or similar)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# HMAC secret for unsubscribe tokens (generate with: openssl rand -hex 32)
UNSUBSCRIBE_SECRET=

# Base URL for email links
BASE_URL=https://privdna.com
